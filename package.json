{
  "name": "@finance-hub/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many -t serve -p api,web --parallel=2",
    "dev:api": "nx serve api",
    "dev:web": "nx serve web",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:e2e": "nx run-many -t e2e",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "20.8.4",
    "@nx/eslint-plugin": "^22.7.2",
    "@nx/js": "20.8.4",
    "@nx/workspace": "20.8.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "~8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nx": "20.8.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^22.0.0",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
